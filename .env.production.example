# Copy this file to .env.production before running Docker Compose or GitHub Actions deploys.

TAG=latest
BACKEND_HOST_PORT=8080
FRONTEND_HOST_PORT=3000
POSTGRES_HOST_PORT=5432

# Frontend build-time variables.
VITE_API_BASE_URL=https://api.your-domain.com/api
VITE_GOOGLE_CLIENT_ID=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_ENABLE_PHONE_AUTH=false
VITE_REQUIRE_PHONE_VERIFICATION_BEFORE_ORDER=false
VITE_PHONEPE_ENABLED=false
VITE_SAMPLE_COUPON_CODE=WELCOME10
VITE_SAMPLE_COUPON_HINT=Use this launch coupon at checkout.

# Backend runtime variables.
PORT=8080
SPRING_DATASOURCE_URL=jdbc:postgresql://your-rds-endpoint:5432/candleora
SPRING_DATASOURCE_USERNAME=candleora
SPRING_DATASOURCE_PASSWORD=change-me
SPRING_FLYWAY_LOCATIONS=classpath:db/vendor-migrations/postgresql
SPRING_JPA_HIBERNATE_DDL_AUTO=update
JWT_SECRET=replace-with-a-32-plus-character-secret
FRONTEND_URL=https://your-domain.com
BACKEND_URL=https://api.your-domain.com
FRONTEND_ORIGIN_PATTERNS=https://your-domain.com,https://www.your-domain.com

GOOGLE_CLIENT_ID=
FIREBASE_PROJECT_ID=

SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

APP_INVOICE_FROM_EMAIL=orders@your-domain.com
APP_INVOICE_SUPPORT_EMAIL=support@your-domain.com
APP_INVOICE_COMPANY_NAME=CandleOra
APP_REQUIRE_PHONE_VERIFICATION_BEFORE_ORDER=false
APP_ORDER_CANCELLATION_WINDOW_MINUTES=30

APP_SAMPLE_COUPON_ENABLED=false
APP_SAMPLE_COUPON_CODE=WELCOME10
APP_SAMPLE_COUPON_TYPE=PERCENTAGE
APP_SAMPLE_COUPON_VALUE=10
APP_SAMPLE_COUPON_MAX_DISCOUNT=300
APP_SAMPLE_COUPON_MIN_ORDER_AMOUNT=499
APP_SAMPLE_COUPON_USAGE_LIMIT=1000

RESEND_API_KEY=
RESEND_BASE_URL=https://api.resend.com

PHONEPE_BASE_URL=https://api-preprod.phonepe.com/apis/pg-sandbox
PHONEPE_MERCHANT_ID=
PHONEPE_SALT_KEY=
PHONEPE_SALT_INDEX=1

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Optional local PostgreSQL container values when you use:
# docker compose --profile local-db up -d
POSTGRES_DB=candleora
POSTGRES_USER=candleora
POSTGRES_PASSWORD=change-me
